# Environment Configuration
NODE_ENV=development

# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/industrial-ai

# JWT
JWT_SECRET=your-super-secret-jwt-key-keep-it-safe
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key
REFRESH_TOKEN_EXPIRE=7d

# Email (for verification/password reset - use SMTP or service like SendGrid)
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=test@ethereal.email
EMAIL_PASS=testpassword
EMAIL_FROM=Industrial AI <no-reply@industrialai.com>
